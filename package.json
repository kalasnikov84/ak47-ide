{
  "name": "ak47-python-ide",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Fast and Lightweight Python IDE",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run tauri dev",
    "tauri:build": "npm run tauri build",
    "tauri:build:linux": "npm run tauri build -- --target x86_64-unknown-linux-gnu",
    "tauri:build:windows": "npm run tauri build -- --target x86_64-pc-windows-msvc"
  },
