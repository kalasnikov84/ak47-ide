{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "main-capability",
  "description": "Main application capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:read-dirs",
    "fs:read-files",
    "fs:write-files",
    "fs:scope-home-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-document-recursive",
    "fs:scope-download-recursive",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask"
  ]
}
